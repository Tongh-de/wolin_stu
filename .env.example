# 沃林学生管理系统 - 环境变量配置
# 请复制此文件为 .env 并填入实际配置值
# cp .env.example .env

# ============ 必填配置 ============

# 数据库配置
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/wolin_test1?charset=utf8mb4

# API密钥配置（至少配置一个）
# 阿里云 DashScope (用于 RAG 知识库和 Agent 功能)
DASHSCOPE_API_KEY=sk-950da4fd8b9a4f3680b5ec8467afafab

# Kimi API (用于自然语言查询)
KIMI_API_KEY=sk-eQhMHU3zGxjre8zt2gsE3AWbqt5PeFnbGCA3c2LpbAYnmpNI

# DeepSeek API (可选，用于代码生成)
DEEPSEEK_API_KEY=sk-d9ceb5c0bccf4bb8a21095015a06cd85

# OpenAI API (可选)
OPENAI_API_KEY=

# JWT认证配置（至少 32 个字符）
# 推荐生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-at-least-32-characters-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============ 可选配置 ============

# CORS配置（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8082,http://127.0.0.1:8082

# 应用配置
DEBUG=false
LOG_LEVEL=INFO

# 向量数据库配置
CHROMA_DB_PATH=./chroma_db
CHROMA_PERSIST=true

# Milvus 向量数据库配置（可选）
MILVUS_HOST=192.168.184.128
MILVUS_PORT=19530
RAG_COLLECTION_NAME=rag_knowledge

# 安全配置
MAX_REQUEST_SIZE=10485760
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
RATE_LIMIT=100/minute
