# 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# 数据库配置
SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/student_management
SQL_ECHO=false

# API密钥配置
DASHSCOPE_API_KEY=your-dashscope-api-key-here
KIMI_API_KEY=your-kimi-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# JWT认证配置
SECRET_KEY=your-secure-secret-key-change-this-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8082,http://127.0.0.1:8082

# 应用配置
DEBUG=false
LOG_LEVEL=INFO

# 向量数据库配置
CHROMA_DB_PATH=./chroma_db
CHROMA_PERSIST=true

# 安全配置
MAX_REQUEST_SIZE=10485760  # 10MB
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
RATE_LIMIT=100/minute
