# 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# 数据库配置
SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/wolin_test1?charset=utf8mb4
SQL_ECHO=false

# API密钥配置 (请替换为你的实际密钥)
DASHSCOPE_API_KEY=your-api-key-here
KIMI_API_KEY=your-api-key-here
DEEPSEEK_API_KEY=your-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# JWT认证配置 (请生成一个强密钥替换)
SECRET_KEY=your-secure-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8082,http://127.0.0.1:8082

# 应用配置
DEBUG=false
LOG_LEVEL=INFO

# 向量数据库配置
CHROMA_DB_PATH=./chroma_db
CHROMA_PERSIST=true

# Milvus 向量数据库配置
MILVUS_HOST=192.168.184.128
MILVUS_PORT=19530
RAG_COLLECTION_NAME=rag_knowledge

# 安全配置
MAX_REQUEST_SIZE=10485760  # 10MB
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
RATE_LIMIT=100/minute
